# YandexGPT
YANDEX_GPT_API_KEY=       # IAM или API-ключ
YANDEX_GPT_FOLDER_ID=     # ID каталога Yandex Cloud
YANDEX_GPT_MODEL=yandexgpt/latest

# MSSQL
MSSQL_SA_PASSWORD=        # пароль SA для SQL Server
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=service_desk_tdbb
MSSQL_USER=SA

# Telegram — основной бот (сотрудники)
TELEGRAM_BOT_TOKEN=       # токен от @BotFather

# Telegram — Admin Bot
ADMIN_BOT_TOKEN=          # отдельный токен от @BotFather для admin-бота
# Супер-админ: единственный, кто может добавлять/удалять других админов
SUPER_ADMIN_ID=           # Telegram user_id суперадмина
# Обычные админы хранятся в data/admins.json (управляются суперадмином через бота)

# API
API_PUBLIC_URL=http://localhost:8001

# Прочее
USE_TF=0
